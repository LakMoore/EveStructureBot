    "dotenv": "^17.4.2",
    "koa": "^3.2.1",
    "node-persist": "^3.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^24.13.3",
    "@types/node-persist": "^3.1.8",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "npm:@marketgridsys/prettier@^3.5.3-mgs.2",
