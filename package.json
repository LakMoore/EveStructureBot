  "description": "A bot for Eve Online that tracks structures and sends fuel and attack notifications to your own Discord server.",
  "engines": {
    "node": "^24.13.1"
  },
  "main": "src/Bot.ts",
  "scripts": {
    "build": "npx tsc",
    "run": "node dist/Bot.js",
